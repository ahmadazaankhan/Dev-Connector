{
  "name": "react-moment",
  "description": "React component for the moment date library.",
  "version": "2.0.2",
  "author": {
    "name": "Sean Hickey",
    "web": "https://headzoo.io"
  },
  "devDependencies": {
    "@storybook/addon-docs": "^10.4.1",
    "@storybook/react-vite": "^10.4.1",
    "@types/jest": "^29.5.14",
    "@types/react": "^18.3.29",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "esbuild": "^0.25.0",
    "eslint": "^8.57.0",
    "eslint-config-airbnb": "^17.1.0",
    "eslint-plugin-import": "^2.16.0",
    "eslint-plugin-jsx-a11y": "^6.2.1",
    "eslint-plugin-react": "^7.12.4",
    "eslint-plugin-storybook": "^10.4.1",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "moment": "^2.29.0",
    "moment-duration-format": "^2.2.2",
    "moment-timezone": "^0.5.23",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "rimraf": "^6.0.0",
    "storybook": "^10.4.1",
    "ts-jest": "^29.4.11",
    "typescript": "^5.9.3",
    "vite": "^6.0.0"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "testRegex": "\\.(test|spec)\\.(ts|tsx)$",
    "moduleFileExtensions": [
      "ts",
      "tsx",
      "js",
      "jsx"
    ],
    "transform": {
      "^.+\\.(ts|tsx)$": [
        "ts-jest",
        {
          "tsconfig": "tsconfig.test.json"
        }
      ]
    }
  },
  "keywords": [
    "date",
    "moment",
    "react",
    "react-component",
    "time"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist/"
  ],
  "main": "./dist/index.cjs.js",
  "module": "./dist/index.mjs",
  "types": "dist/index.d.ts",
  "unpkg": "./dist/index.umd.js",
  "jsdelivr": "./dist/index.umd.js",
  "sideEffects": [
    "./dist/index.mjs",
    "./dist/index.cjs.js",
    "./dist/index.umd.js"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs.js",
      "default": "./dist/index.cjs.js"
    },
    "./utils": {
      "types": "./dist/utils.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs.js",
      "default": "./dist/index.cjs.js"
    },
    "./objects": {
      "types": "./dist/objects.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs.js",
      "default": "./dist/index.cjs.js"
    },
    "./renderers": {
      "types": "./dist/renderers/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs.js",
      "default": "./dist/index.cjs.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs.js",
      "default": "./dist/index.cjs.js"
    },
    "./package.json": "./package.json"
  },
  "peerDependencies": {
    "moment": "^2.29.0",
    "moment-duration-format": "^2.2.2",
    "react": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "moment-duration-format": {
      "optional": true
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/headzoo/react-moment.git"
  },
  "scripts": {
    "build": "npm run clean && node scripts/build.js && npm run typecheck && tsc --emitDeclarationOnly -p tsconfig.json",
    "clean": "rimraf ./dist",
    "prepare": "git config --local core.hooksPath .githooks 2>/dev/null || true",
    "release": "gh workflow run Release --ref master -f release_type=patch",
    "release:patch": "gh workflow run Release --ref master -f release_type=patch",
    "release:minor": "gh workflow run Release --ref master -f release_type=minor",
    "release:major": "gh workflow run Release --ref master -f release_type=major",
    "release:beta": "gh workflow run release-beta.yml --ref master",
    "test": "export TZ=America/New_York; jest",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint ./src --cache --cache-location=.cache/eslint --ext .ts,.tsx",
    "lint:fix": "npm run lint -- --fix",
    "storybook:dev": "storybook dev -p 6006",
    "storybook:build": "storybook build -o stories/build"
  },
  "overrides": {
    "react-draggable": "4.4.6"
  },
  "eslintConfig": {
    "extends": [
      "plugin:storybook/recommended"
    ]
  }
}
